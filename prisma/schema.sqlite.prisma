generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Currency {
  id        String    @id @default(cuid())
  code      String    @unique
  name      String
  symbol    String
  companies Company[]
}

model Company {
  id                  String             @id @default(cuid())
  code                String             @unique
  name                String
  country             String
  currency            String
  currencyMaster      Currency           @relation(fields: [currency], references: [code])
  city                String
  status              String             @default("Active")
  fiscalYearVariant   FiscalYearVariant? @relation(fields: [fiscalYearVariantId], references: [id])
  fiscalYearVariantId String?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  journalEntries      JournalEntry[]
  customers           Customer[]
  vendors             Vendor[]
}

model FiscalYearVariant {
  id             String    @id @default(cuid())
  code           String    @unique
  name           String
  periods        Int
  specialPeriods Int       @default(4)
  yearDependent  Boolean   @default(false)
  companies      Company[]
}

model ChartOfAccounts {
  id         String      @id @default(cuid())
  code       String      @unique
  name       String
  language   String      @default("EN")
  glAccounts GLAccount[]
}

model GLAccount {
  id                String          @id @default(cuid())
  accountNumber     String
  name              String
  accountType       String
  isReconciliation  Boolean         @default(false)
  chartOfAccounts   ChartOfAccounts @relation(fields: [chartOfAccountsId], references: [id])
  chartOfAccountsId String
  journalLines      JournalLine[]

  @@unique([accountNumber, chartOfAccountsId])
}

model Customer {
  id        String  @id @default(cuid())
  number    String  @unique
  name      String
  country   String
  city      String
  email     String?
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyId String
}

model Vendor {
  id        String  @id @default(cuid())
  number    String  @unique
  name      String
  country   String
  city      String
  email     String?
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyId String
}

model JournalEntry {
  id           String        @id @default(cuid())
  documentNo   String        @unique
  postingDate  DateTime
  documentDate DateTime
  reference    String?
  headerText   String
  company      Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyId    String
  lines        JournalLine[]
  createdAt    DateTime      @default(now())
}

model JournalLine {
  id             String       @id @default(cuid())
  lineNo         Int
  debit          Float        @default(0)
  credit         Float        @default(0)
  text           String
  journalEntry   JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  journalEntryId String
  glAccount      GLAccount    @relation(fields: [glAccountId], references: [id])
  glAccountId    String
}

model Course {
  id          String            @id @default(cuid())
  slug        String            @unique
  title       String
  description String
  track       String
  level       String
  status      String            @default("Published")
  sequence    Int
  modules     TrainingModule[]
  progress    LearnerProgress[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
}

model TrainingModule {
  id               String            @id @default(cuid())
  slug             String            @unique
  title            String
  description      String
  sequence         Int
  estimatedMinutes Int
  course           Course            @relation(fields: [courseId], references: [id], onDelete: Cascade)
  courseId         String
  lessons          Lesson[]
  practiceTasks    PracticeTask[]
  quizQuestions    QuizQuestion[]
  progress         LearnerProgress[]
}

model Lesson {
  id               String            @id @default(cuid())
  slug             String            @unique
  title            String
  summary          String
  plainEnglish     String
  businessNote     String
  interactiveRoute String?
  sequence         Int
  durationMinutes  Int
  module           TrainingModule    @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  moduleId         String
  progress         LearnerProgress[]
}

model PracticeTask {
  id              String            @id @default(cuid())
  slug            String            @unique
  title           String
  mode            String
  description     String
  expectedOutcome String
  sequence        Int
  module          TrainingModule    @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  moduleId        String
  progress        LearnerProgress[]
}

model QuizQuestion {
  id            String         @id @default(cuid())
  prompt        String
  optionsJson   String
  correctAnswer String
  explanation   String
  sequence      Int
  module        TrainingModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  moduleId      String
}

model LearnerProgress {
  id          String          @id @default(cuid())
  learnerId   String
  progressKey String          @unique
  status      String          @default("Not Started")
  score       Int             @default(0)
  completedAt DateTime?
  updatedAt   DateTime        @updatedAt
  course      Course?         @relation(fields: [courseId], references: [id], onDelete: Cascade)
  courseId    String?
  module      TrainingModule? @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  moduleId    String?
  lesson      Lesson?         @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  lessonId    String?
  task        PracticeTask?   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  taskId      String?
}
